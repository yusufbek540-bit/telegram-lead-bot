# ============================================================
# TELEGRAM LEAD BOT — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Telegram Bot (from @BotFather)
BOT_TOKEN=your_bot_token_here

# OpenAI API
OPENAI_API_KEY=sk-your_openai_key_here

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# TWA URL (update after deploying the web app)
TWA_URL=https://your-twa-domain.vercel.app

# Admin Telegram IDs (comma-separated, for /admin commands)
ADMIN_IDS=123456789

# Agency defaults
DEFAULT_LANG=uz
AGENCY_NAME=YourBrand Agency
